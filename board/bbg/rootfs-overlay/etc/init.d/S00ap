#!/bin/sh
# ============================================================
# S00ap — bring up the Wi-Fi AP as early as possible
# Strategy: nothing non-essential runs before AP-ENABLED.
#           eth0 / DHCP / nftables / httpd all happen AFTER the AP is up.
# ============================================================

# --- 1. Wait for wlan0 to appear (up to 3s) ---
for i in $(seq 1 300); do
    [ -e /sys/class/net/wlan0 ] && break
    sleep 0.01
done

# --- 2. Configure wlan0 and start hostapd (critical path) ---
ip link set wlan0 up
ip addr add 192.168.50.1/24 dev wlan0
mkdir -p /var/run/hostapd
hostapd /etc/hostapd.conf > /dev/console 2>&1 &

# --- 3. Wait for AP-ENABLED (up to 8s) ---
ap_up=0
for i in $(seq 1 800); do
    hostapd_cli status 2>/dev/null | grep -q 'state=ENABLED' && { ap_up=1; break; }
    sleep 0.01
done
[ "$ap_up" -eq 1 ] || echo "hostapd: AP-ENABLED not seen within 8s" > /dev/console

# --- 4. Deferred services (backgrounded so they don't block boot) ---
#     eth0 shares the same musb USB controller as wl18xx and enumerates
#     late behind a hub. Starting it here (after AP) keeps the USB bus
#     and CPU free during wlcore firmware load + hostapd key setup.
(
    dnsmasq -C /etc/dnsmasq-ap.conf
    echo 1 > /proc/sys/net/ipv4/ip_forward
    httpd -h /www -p 80

    # Wait for eth0 to appear (up to 3s)
    for i in $(seq 1 300); do
        [ -e /sys/class/net/eth0 ] && break
        sleep 0.01
    done
    ip link set eth0 up
    udhcpc -i eth0 -t 3 -A 1 -b     # -b: background if no lease

    nft -f /etc/nftables.conf
) &

